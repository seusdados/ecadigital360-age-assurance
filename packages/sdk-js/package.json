{
  "name": "@agekey/sdk-js",
  "version": "0.0.1",
  "description": "Official JavaScript/TypeScript SDK for AgeKey age assurance.",
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js",
      "default": "./dist/server.js"
    },
    "./safety": {
      "types": "./dist/safety.d.ts",
      "import": "./dist/safety.js",
      "default": "./dist/safety.js"
    },
    "./oneclick": {
      "types": "./dist/oneclick.d.ts",
      "import": "./dist/oneclick.js",
      "default": "./dist/oneclick.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@agekey/shared": "workspace:*",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
