{
  "name": "@agekey/shared",
  "version": "0.0.1",
  "private": true,
  "description": "Shared Zod schemas, reason codes, error classes and types for AgeKey.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schemas": "./src/schemas/index.ts",
    "./reason-codes": "./src/reason-codes.ts",
    "./errors": "./src/errors.ts",
    "./types": "./src/types.ts",
    "./privacy-guard": "./src/privacy-guard.ts",
    "./privacy/privacy-guard": "./src/privacy/privacy-guard.ts",
    "./agekey-claims": "./src/agekey-claims.ts",
    "./decision/decision-envelope": "./src/decision/decision-envelope.ts",
    "./taxonomy/reason-codes": "./src/taxonomy/reason-codes.ts",
    "./taxonomy/age-taxonomy": "./src/taxonomy/age-taxonomy.ts",
    "./webhooks/webhook-signer": "./src/webhooks/webhook-signer.ts",
    "./webhooks/webhook-types": "./src/webhooks/webhook-types.ts",
    "./retention/retention-classes": "./src/retention/retention-classes.ts",
    "./policy/policy-types": "./src/policy/policy-types.ts",
    "./policy/policy-engine": "./src/policy/policy-engine.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "vitest": "^2.1.9"
  }
}
