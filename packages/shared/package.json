{
  "name": "@agekey/shared",
  "version": "0.0.1",
  "private": true,
  "description": "Shared Zod schemas, reason codes, error classes and types for AgeKey.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schemas": "./src/schemas/index.ts",
    "./reason-codes": "./src/reason-codes.ts",
    "./errors": "./src/errors.ts",
    "./types": "./src/types.ts",
    "./privacy-guard": "./src/privacy-guard.ts",
    "./agekey-claims": "./src/agekey-claims.ts",
    "./audit-csv": "./src/audit-csv.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "vitest": "^2.1.9"
  }
}
