
digraph G {
  graph [rankdir=LR, bgcolor="white", pad="0.3", nodesep="0.5", ranksep="0.75"];
  node [shape=box, style="rounded", fontname="Arial", fontsize=18, margin="0.16,0.10"];
  edge [fontname="Arial", fontsize=14, arrowsize=0.8];

  tenants [label="tenants"];
  applications [label="applications"];
  policies [label="policies"];
  sessions [label="verification_sessions"];
  challenges [label="verification_challenges"];
  artifacts [label="proof_artifacts"];
  results [label="verification_results"];
  tokens [label="result_tokens"];
  issuers [label="issuers"];

  tenants -> applications;
  tenants -> policies;
  applications -> sessions;
  policies -> sessions;
  sessions -> challenges;
  sessions -> artifacts;
  sessions -> results;
  results -> tokens;
  issuers -> artifacts;
  issuers -> results;
}
